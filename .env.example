# 0xGrantHunter local env (copy to .env and fill - DO NOT COMMIT the real .env)
# Atlas setup completed 2026-06-11 via MCP with 24h owner SA.
# DB user: granthunter-app (readWrite on "granthunter" DB)
# Cluster: 0xGrantHunter (FREE/M0, GCP CENTRAL_US)

# Gemini (for the ADK agent)
GOOGLE_GENAI_API_KEY=your-gemini-key-here

# MongoDB Atlas - full URI with app user (use exactly this pattern for Secret Manager)
MONGODB_ATLAS_URI=mongodb+srv://granthunter-app:<YOUR_PASSWORD>@0xgranthunter.gkpazno.mongodb.net/granthunter?retryWrites=true&w=majority

# GCP project (matches Terraform + Packet)
GOOGLE_CLOUD_PROJECT=boring-access

# For local MCP usage (optional - the ~/.grok/config.toml already has the CONNECTION_STRING)
# export MDB_MCP_CONNECTION_STRING="$MONGODB_ATLAS_URI"
